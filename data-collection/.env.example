# YouTube Data API v3 key
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project
# Free tier: 10,000 quota units/day (sufficient for weekly collection)
#
# Also add this as a GitHub repo secret named YOUTUBE_API_KEY
# for the CI workflow to work.
YOUTUBE_API_KEY=your_api_key_here

# FRED API key (Federal Reserve Economic Data)
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# Used by fred-collector.py to pull live economic data for official scores
FRED_API_KEY=your_fred_api_key_here

# Bluesky credentials (AT Protocol)
# Create an App Password at: https://bsky.app/settings/app-passwords
# Needed because unauthenticated API requests get 403 from shared CI IPs.
# Also add these as GitHub repo secrets named BLUESKY_HANDLE and BLUESKY_APP_PASSWORD.
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password_here

# Reddit OAuth2 credentials
# Create a "script" or "installed" app at: https://www.reddit.com/prefs/apps
# Only client_credentials grant is used (read-only, no username/password needed).
# Also add these as GitHub repo secrets named REDDIT_CLIENT_ID and REDDIT_CLIENT_SECRET.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
